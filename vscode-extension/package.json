{
  "name": "swibe-language",
  "displayName": "Swibe",
  "description": "Sovereign Agent-Native Scripting Language — syntax highlighting, LSP, IDE bridge, session management for Swibe",
  "version": "3.1.0",
  "publisher": "bino-elgua",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": [
    "swibe", "agent", "ai", "sovereign",
    "llm", "openclaw", "techgnosis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Bino-Elgua/Swibe"
  },
  "homepage": "https://github.com/Bino-Elgua/Swibe#readme",
  "bugs": {
    "url": "https://github.com/Bino-Elgua/Swibe/issues"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:swibe"
  ],
  "contributes": {
    "languages": [{
      "id": "swibe",
      "aliases": ["Swibe", "swibe"],
      "extensions": [".swibe"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "swibe",
      "scopeName": "source.swibe",
      "path": "./syntaxes/swibe.tmLanguage.json"
    }],
    "snippets": [{
      "language": "swibe",
      "path": "./snippets/swibe.json"
    }],
    "themes": [
      {
        "label": "Swibe Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/swibe-dark.json"
      },
      {
        "label": "Swibe Light",
        "uiTheme": "vs",
        "path": "./themes/swibe-light.json"
      }
    ],
    "commands": [
      { "command": "swibe.openRepl",         "title": "Swibe: Open REPL" },
      { "command": "swibe.compile",          "title": "Swibe: Compile File" },
      { "command": "swibe.run",              "title": "Swibe: Run File" },
      { "command": "swibe.compileOpenClaw",  "title": "Swibe: Compile to OpenClaw" },
      { "command": "swibe.bridgeConnect",    "title": "Swibe: Connect Bridge" },
      { "command": "swibe.bridgeDisconnect", "title": "Swibe: Disconnect Bridge" },
      { "command": "swibe.sessionCreate",    "title": "Swibe: Create Session" },
      { "command": "swibe.sessionResume",    "title": "Swibe: Resume Session" },
      { "command": "swibe.sessionPanel",     "title": "Swibe: Session Panel" },
      { "command": "swibe.evalSelection",    "title": "Swibe: Evaluate Selection" },
      { "command": "swibe.format",           "title": "Swibe: Format Document" }
    ],
    "keybindings": [
      { "command": "swibe.evalSelection",   "key": "ctrl+shift+e", "when": "editorLangId == swibe" },
      { "command": "swibe.compile",          "key": "ctrl+shift+b", "when": "editorLangId == swibe" },
      { "command": "swibe.openRepl",         "key": "ctrl+shift+r", "when": "editorLangId == swibe" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.0"
  }
}
