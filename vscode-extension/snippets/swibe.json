{
  "Think": {
    "prefix": "think",
    "body": ["think \"${1:your prompt}\""],
    "description": "LLM reasoning with receipt"
  },
  "Swarm": {
    "prefix": "swarm",
    "body": [
      "swarm {",
      "\t${1:think \"task\"}",
      "}"
    ],
    "description": "Multi-agent coordination"
  },
  "Ethics": {
    "prefix": "ethics",
    "body": [
      "ethics { ${1:harm-none} }"
    ],
    "description": "Ethics enforcement"
  },
  "Hermetic Ethics": {
    "prefix": "hermetic",
    "body": [
      "ethics {",
      "\tmode: \"hermetic\"",
      "\tharm-none",
      "\taudit-trail",
      "}"
    ],
    "description": "7 Hermetic Principles enforcement"
  },
  "Birth": {
    "prefix": "birth",
    "body": [
      "birth {",
      "\tidentity: \"bipọn39\"",
      "}"
    ],
    "description": "Sovereign agent birth"
  },
  "Budget": {
    "prefix": "budget",
    "body": [
      "budget { tokens: ${1:10000}; time: \"${2:30s}\" }"
    ],
    "description": "Resource budget"
  },
  "Remember": {
    "prefix": "remember",
    "body": ["remember { \"${1:key}\" }"],
    "description": "Persistent memory"
  },
  "Evolve": {
    "prefix": "evolve",
    "body": [
      "evolve { soul: \"${1:Ọbàtálá}\", rank: ${2:1} }"
    ],
    "description": "Soul evolution"
  },
  "Heartbeat": {
    "prefix": "heartbeat",
    "body": [
      "heartbeat { every: ${1:60s}; check: \"${2:any updates?}\" }"
    ],
    "description": "Autonomous scheduling"
  },
  "Main function": {
    "prefix": "fn main",
    "body": [
      "fn main() {",
      "\t${1:think \"hello\"}",
      "}"
    ],
    "description": "Main function"
  },
  "OpenClaw agent": {
    "prefix": "openclaw",
    "body": [
      "fn main() {",
      "\tbirth { identity: \"bipọn39\" }",
      "\tethics { harm-none }",
      "\tbudget { tokens: 50000; time: \"300s\" }",
      "\tthink \"${1:What can I help with?}\"",
      "\tremember { \"${2:session}\" }",
      "\theartbeat { every: 300s; check: \"any tasks?\" }",
      "}"
    ],
    "description": "Full OpenClaw agent template"
  }
