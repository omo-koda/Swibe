{
  "name": "Swibe",
  "scopeName": "source.swibe",
  "fileTypes": ["swibe"],
  "patterns": [
    {
      "name": "comment.line.swibe",
      "match": "--.*$"
    },
    {
      "name": "keyword.control.swibe",
      "match": "\\b(fn|if|else|loop|until|return|let|const)\\b"
    },
    {
      "name": "keyword.primitive.swibe",
      "match": "\\b(think|swarm|chain|plan|ethics|birth|budget|remember|evolve|heartbeat|observe|retrieve|share|dispatch|neural|meta-digital|secure|hybrid|skill|load|println|emit)\\b"
    },
    {
      "name": "keyword.modifier.swibe",
      "match": "\\b(harm-none|audit-trail|hermetic|mode|every|check|tokens|time|soul|rank|key|arweave|telephony|identity)\\b"
    },
    {
      "name": "string.quoted.double.swibe",
      "begin": "\"",
      "end": "\"",
      "patterns": [{
        "name": "constant.character.escape.swibe",
        "match": "\\\\."
      }]
    },
    {
      "name": "constant.numeric.swibe",
      "match": "\\b[0-9]+(s|ms|k|M|B)?\\b"
    },
    {
      "name": "constant.language.swibe",
      "match": "\\b(true|false|null)\\b"
    },
    {
      "name": "entity.name.function.swibe",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
    },
    {
      "name": "variable.swibe",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    {
      "name": "punctuation.swibe",
      "match": "[{}()\\[\\];,:]"
    },
    {
      "name": "keyword.operator.swibe",
      "match": "[+\\-*/<>=!&|]+"
    }
  ]
}
