### 6. `src/parser/recovery.js` — Graceful Error Recovery
```js
// Add: Panic-mode recovery for REPL resilience
function recoverFromError(parser, expectedTokens) {
  let depth = 0;
  
  while (!parser.isEOF()) {
    const token = parser.peek();
    
    // Sync to next statement boundary
    if (token.type === 'SEMICOLON' || token.type === 'EOF') {
      parser.advance();
      break;
    }
    
    // Handle nested block recovery
    if (token.type === 'LBRACE') depth++;
    if (token.type === 'RBRACE') {
      depth--;
      if (depth < 0) { parser.advance(); break; }
    }
    
    parser.advance();
  }
  
  return { recovered: true, skipped: parser.position };
}
