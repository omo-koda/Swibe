### 10. `src/layers/validator.js` — Compile-Time Layer Enforcement
```js
// NEW: Static analysis pass before execution
function validateLayerOrder(ast) {
  const layerMap = {
    'EthicsStatement': 0, 'BirthStatement': 0, 'SecureStatement': 0,
    'ThinkStatement': 1, 'PermissionStatement': 1, 'BudgetStatement': 1,
    'SwarmStatement': 2, 'TeamStatement': 2, 'CoordinateStatement': 2,
    'PilotStatement': 3, 'WitnessStatement': 3, 'McpStatement': 3
  };
  
  let maxLayerSeen = -1;
  
  for (const node of ast.body) {
    const layer = layerMap[node.type];
    if (layer === undefined) continue;
    
    if (layer < maxLayerSeen) {
      return {
        valid: false,
        error: `[COMPILER:LAYER-ORDER] Layer ${layer} (${node.type}) declared after Layer ${maxLayerSeen}`
      };
    }
    maxLayerSeen = Math.max(maxLayerSeen, layer);
  }
  
  return { valid: true };
}
```

