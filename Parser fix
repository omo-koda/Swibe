function tokenize(input) {
  // ... existing logic ...
  
  // NEW: Track brace depth to avoid premature block termination
  let braceDepth = 0;
  let inString = false;
  let stringChar = null;
  
  for (let i = 0; i < input.length; i++) {
    const char = input[i];
    
    // Handle string boundaries (respect escaped quotes)
    if ((char === '"' || char === "'") && input[i-1] !== '\\') {
      if (!inString) { inString = true; stringChar = char; }
      else if (char === stringChar) { inString = false; }
      continue;
    }
    
    // Only count braces outside strings
    if (!inString) {
      if (char === '{') braceDepth++;
      if (char === '}') braceDepth--;
    }
    
    // ... rest of tokenization ...
  }
}
