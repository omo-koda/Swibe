-- THE SOVEREIGN DEMO
-- One file. Full stack. No explanation needed.

swarm {
  Oracle: Agent {
    role: "thinker",
    goal: "What is the most important thing a sovereign AI must never forget?"
  } @elixir =>
  Auditor: Agent {
    role: "verifier",
    goal: "audit receipt from Oracle"
  } @elixir =>
  Scribe: Agent {
    role: "minter",
    goal: "mint soul_token and seal receipt"
  } @move
}

fn main() {
  println("Technosis Sovereign Demo — v1.0")
  trace("The organism has spoken.")
}
