-- Swibe Meta-Digital Demo
-- Demonstrates the neutralized meta-digital primitive.

meta-digital "patrol" { 
  ethics: refuse_if("spam"); 
  output: seal("Task complete."); 
}

fn main() {
  println("--- Meta-Digital Demo ---")
  
  -- The meta-digital declaration creates a 'patrol' object
  -- We call its run method
  let result = patrol.run("Start security sweep")
  println("Result: " + result)
  
  println("--- Demo Complete ---")
}
