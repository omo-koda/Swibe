{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-case-declarations": "error",
    "prefer-const": "error",
    "no-constant-condition": "off",
    "no-dupe-keys": "error"
  }
}
