# Vibe Language Configuration

# LLM Provider: claude, ollama, hf, or grok
LLM_PROVIDER=claude

# Claude API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# HuggingFace Token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Ollama (local, free - run: ollama serve)
OLLAMA_URL=http://localhost:11434

# Registry fallback (custom registry, optional)
SWIBE_REGISTRY=https://registry.npmjs.org
# Future: https://registry.swibe.dev

# Grok API Key (https://x.ai/api)
XAI_API_KEY=your-key-here

# Target language for compilation (default: javascript)
TARGET_LANGUAGE=javascript

# Debug mode
DEBUG=false

# Loop max attempts for loop-until (default 10)
SWIBE_LOOP_MAX=10

# OpenRouter (free tier — no billing required)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=optional_your_key_here
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Free models available (no cost):
# meta-llama/llama-3.3-70b-instruct:free
# mistralai/mistral-7b-instruct:free
# google/gemma-2-9b-it:free
