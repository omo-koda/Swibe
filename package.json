{
  "name": "@bino-elgua/swibe",
  "version": "3.0.7",
  "description": "Agent-native scripting language. 39+ compile targets. Sovereign by design.",
  "main": "src/index.js",
  "bin": {
    "swibe": "src/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "repl": "node src/index.js repl",
    "compile": "node src/compiler.js",
    "run": "node src/index.js run",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "roadmap": "node src/roadmap-cli.js"
  },
  "keywords": [
    "agents",
    "ai",
    "swarm",
    "elixir",
    "rust",
    "sovereign",
    "blockchain",
    "swibe"
  ],
  "author": "Bino Elgua",
  "license": "MIT",
  "homepage": "https://github.com/Bino-Elgua/Swibe",
  "dependencies": {
    "dotenv": "^17.3.1",
    "tweetnacl": "^1.0.3",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "vitest": "^1.0.0"
  },
  "optionalDependencies": {
    "isolated-vm": "^6.1.2"
  }
}
