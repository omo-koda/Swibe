{
  "name": "@bino-elgua/swibe",
  "version": "0.2.1",
  "description": "Compact, agent-native scripting language with autonomous loops and swarms",
  "main": "src/index.js",
  "bin": {
    "swibe": "./src/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "repl": "node src/repl.js",
    "compile": "node src/compiler.js",
    "run": "node src/index.js run",
    "test": "node src/vibe-test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "roadmap": "node src/roadmap-cli.js"
  },
  "keywords": [
    "ai",
    "agent",
    "swarm",
    "vibe",
    "language",
    "compiler",
    "prompt",
    "llm",
    "rag"
  ],
  "author": "Bino Elgua",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  }
}
