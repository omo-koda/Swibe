{
  "name": "swibe",
  "version": "0.1.0",
  "description": "Compact, agent-native scripting language with autonomous loops and swarms",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "repl": "node src/repl.js",
    "compile": "node src/compiler.js",
    "test": "node --test src/**/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "roadmap": "node src/roadmap-cli.js",
    "roadmap:status": "node src/roadmap-cli.js status",
    "roadmap:todos": "node src/roadmap-cli.js list-todos",
    "roadmap:high": "node src/roadmap-cli.js list-todos HIGH"
  },
  "keywords": [
    "ai",
    "vibe",
    "language",
    "compiler",
    "prompt",
    "voice",
    "llm",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  }
}
